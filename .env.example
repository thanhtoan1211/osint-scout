# OSINT Scout — API Key Configuration
# Copy this file to .env and fill in your keys.

# Shodan (free tier: 1 query/sec, 100 results max)
# Sign up: https://account.shodan.io/register
SHODAN_API_KEY=your_shodan_api_key_here

# Censys (free tier: 250 queries/month)
# Sign up: https://search.censys.io/register
CENSYS_API_ID=your_censys_api_id_here
CENSYS_API_SECRET=your_censys_api_secret_here

# HackerTarget (optional — 100 queries/day free without key)
# Sign up for more: https://hackertarget.com/membership/
HACKERTARGET_API_KEY=your_hackertarget_api_key_here
